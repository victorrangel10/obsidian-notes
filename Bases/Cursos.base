filters:
  and:
    - '!file.inFolder("Templates")'

views:
  - type: table
    name: Table
    filters:
      and:
        - Categorias.contains(link("Cursos"))
    order:
      - file.link
      - file.mtime
    sort:
      - property: file.mtime
        direction: DESC
    summaries:
      file.link: Filled
