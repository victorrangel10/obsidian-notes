filters:
  and:
    - '!file.inFolder("Templates")'
    - type == "aula"
    - curso == link("A Arte de Decidir")
views:
  - type: cards
    name: Aulas
    order:
      - file.name
      - tags
      - file.link
      - data_criacao
      - type
    sort:
      - property: ordem
        direction: ASC
