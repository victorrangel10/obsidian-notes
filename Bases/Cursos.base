filters:
  and:
    - '!file.inFolder("Templates")'
views:
  - type: table
    name: Table
    filters:
      and:
        - Categorias.contains(link("Cursos"))
    order:
      - file.name
      - autor
      - status
      - data_inicio
      - rating
      - tags
    sort:
      - property: file.name
        direction: ASC
      - property: status
        direction: DESC
      - property: file.mtime
        direction: DESC
    summaries:
      file.link: Filled
