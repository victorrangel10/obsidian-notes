filters:
  and:
    - '!file.inFolder("Templates")'
    - type == "aula"
views:
  - type: cards
    name: Aulas
    filters:
      and:
        - type == "aula"
    order:
      - file.name
      - tags
      - file.link
      - data_criacao
      - type
    sort:
      - property: ordem
        direction: ASC
  - type: cards
    name: System Design
  - type: cards
    name: A Arte de Decidir
    filters:
      and:
        - curso == link("A Arte de Decidir")
